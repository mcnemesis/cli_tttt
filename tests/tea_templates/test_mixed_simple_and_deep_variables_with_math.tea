###########################################
# TEA TEMPLATE EXPRESSIONS
# Allow us to write complex expressions that
# can resolve to terminal value expressions
# in a RECURSIVE manner similar to variable substitution
# in some higher-level programming language
# templating systems
# ##########################################

# TEST CASE: we want to evaluate a template that mixes:
#  normal text, variables and mathematics
#  DETAILS: in the TEA TAZ R: (REWRITE) chapter

v:vEXPR:{The value was computed as: ##vInnerVALUE##}
v:a:2
v:b:{(1/#a#)}


v:innerEXPR:{1+100*5-(1-#a#**#b#)}
r*!@:innerEXPR
r.: | v:vInnerVALUE
r*!@:vEXPR

# should return
#The value was computed as: 501.4142135623731

# we could also use non-vault R@: versions...

v:a:2
v:b:{(1/#a#)}
i!:{1+100*5-(1-#a#**#b#)} | r@:
# OR just..
r!@:{1+100*5-(1-#a#**#b#)} 

# then evaluate inner expression first..
r.: | v:vInnerVALUE

# then do original template...
r!@:{The value was computed as: ##vInnerVALUE##}
